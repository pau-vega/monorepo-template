{
  "name": "monorepo-template",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "test": "turbo test",
    "e2e": "turbo e2e",
    "test:coverage": "turbo test -- --coverage",
    "nuke": "find . -type d \\( -name node_modules -o -name dist -o -name build -o -name .turbo -o -name .next -o -name .cache -o -name coverage \\) -prune -exec rm -rf '{}' +",
    "phoenix": "pnpm nuke && pnpm install",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/node24": "^24.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "husky": "^9.1.7",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.16",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "@types/node": "^25.5.0"
  }
}
